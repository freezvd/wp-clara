					"size": "2.8rem"
				},
				{
					"slug": "3xl-sm",
					"name": "3XL Small",
					"size": "3.2rem"
				},
				{
					"slug": "3xl",
					"name": "3XL",
					"size": "3.6rem"
				},
				{
					"slug": "4xl",
					"name": "4XL",
					"size": "4rem"
				},
				{
					"slug": "4xl-lg",
