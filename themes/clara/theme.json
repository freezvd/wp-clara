				},
				{
					"slug": "hero-min",
					"name": "Hero Min",
					"size": "clamp(5.2rem, 8vw, 10rem)",
					"fluid": false
				},
				{
					"slug": "display",
					"name": "Display",
					"size": "clamp(5rem, 7vw, 9rem)",
					"fluid": false
				},
				{
					"slug": "heading-lg",
					"name": "Heading Large",
					"size": "clamp(3.6rem, 5vw, 5.8rem)",
					"fluid": false
				},
				{
					"slug": "heading-md",
					"name": "Heading Medium",
					"size": "clamp(3.2rem, 4vw, 5.2rem)",
					"fluid": false
				},
				{
					"slug": "heading-sm",
					"name": "Heading Small",
					"size": "clamp(2.8rem, 3.5vw, 4.4rem)",
					"fluid": false
				},
				{
					"slug": "subheading",
					"name": "Subheading",
					"size": "clamp(2rem, 2.5vw, 2.8rem)",
					"fluid": false
				},
				{
					"slug": "quote",
					"name": "Quote",
					"size": "clamp(2.4rem, 3.5vw, 4rem)",
					"fluid": false
				},
				{
					"slug": "intro",
					"name": "Intro",
					"size": "clamp(1.6rem, 2vw, 2rem)",
					"fluid": false
				}
			]
		},
		"spacing": {},
		"layout": {
			"contentSize": "1140px",
			"wideSize": "1400px"
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--parchment)",
			"text": "var(--wp--preset--color--text-body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontWeight": "300",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--burg)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--burg-mid)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "300",
					"fontStyle": "italic",
					"fontSize": "var(--wp--preset--font-size--display)",
					"lineHeight": "1"
				},
				"color": {
					"text": "var(--wp--preset--color--cream)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "300",
					"fontStyle": "italic",
					"fontSize": "var(--wp--preset--font-size--heading-lg)",
					"lineHeight": "1.1"
				},
				"color": {
					"text": "var(--wp--preset--color--gold)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--subheading)",
					"lineHeight": "1.25"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-soft)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--xl-sm)",
					"lineHeight": "1.3"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-soft)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--md)",
					"letterSpacing": "0.16em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--text-body)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--base)",
					"letterSpacing": "0.28em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--gold)"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"letterSpacing": "0.22em",
					"textTransform": "uppercase"
				},
				"color": {
					"background": "var(--wp--preset--color--burg)",
					"text": "var(--wp--preset--color--parchment)"
				},
				"spacing": {
					"padding": {
						"top": "1.6em",
						"bottom": "1.6em",
						"left": "4em",
						"right": "4em"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--burg-mid)"
					}
				}
			}
		}
	},
	"customTemplates": [
		{ "name": "page-despre-mine", "title": "Despre Mine",    "postTypes": ["page"] },
		{ "name": "page-terapii",     "title": "Terapii",        "postTypes": ["page"] },
		{ "name": "page-ritualuri",   "title": "Ritualuri",      "postTypes": ["page"] },
		{ "name": "page-tarife",      "title": "Tarife",         "postTypes": ["page"] },
		{ "name": "page-contact",     "title": "Contact",        "postTypes": ["page"] },
		{ "name": "single-service",   "title": "Single Service", "postTypes": ["page"] }
	],
	"templateParts": [
		{ "name": "header",     "title": "Header",     "area": "header" },
		{ "name": "footer",     "title": "Footer",     "area": "footer" },
		{ "name": "breadcrumb", "title": "Breadcrumb", "area": "uncategorized" }
	]
}