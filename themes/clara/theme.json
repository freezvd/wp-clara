					"size": "1.7rem"
				},
				{
					"slug": "lg-sm",
					"name": "Large Small",
					"size": "1.8rem"
				},
				{
					"slug": "lg",
					"name": "Large",
					"size": "1.9rem"
				},
				{
					"slug": "xl-xs",
					"name": "XL XS",
					"size": "2rem"
				},
				{
					"slug": "xl-sm",
					"name": "XL Small",
					"size": "2.1rem"
				},
				{
					"slug": "xl",
					"name": "XL",
					"size": "2.2rem"
				},
				{
					"slug": "xl-lg",
					"name": "XL Large",
					"size": "2.4rem"
				},
				{
					"slug": "2xl-sm",
					"name": "2XL Small",
					"size": "2.6rem"
				},
				{
					"slug": "2xl",
