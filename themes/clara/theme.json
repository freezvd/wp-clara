		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "serif",
					"name": "Cormorant Garamond",
					"fontFamily": "'Cormorant Garamond', Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Cormorant Garamond",
							"fontWeight": "300 500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/CormorantGaramond.woff2" ]
						},
						{
							"fontFamily": "Cormorant Garamond",
							"fontWeight": "300 500",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/CormorantGaramond-Italic.woff2" ]
						}
					]
				},
				{
					"slug": "sans",
					"name": "Raleway",
					"fontFamily": "'Raleway', 'Helvetica Neue', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Raleway",
							"fontWeight": "300 600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Raleway.woff2" ]
						},
						{
							"fontFamily": "Raleway",
							"fontWeight": "300 600",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Raleway-Italic.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"name": "XS",
					"size": "0.8rem"
				},
				{
					"slug": "s",
					"name": "S",
					"size": "0.9rem"
				},
				{
					"slug": "base",
					"name": "Base",
					"size": "1rem"
				},
				{
					"slug": "sm",
					"name": "Small",
					"size": "1.1rem"
				},
				{
					"slug": "md-xs",
