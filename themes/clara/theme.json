					"size": "1.3rem"
				},
				{
					"slug": "md",
					"name": "Medium",
					"size": "1.4rem"
				},
				{
					"slug": "body",
					"name": "Body",
					"size": "1.6rem"
				},
				{
					"slug": "md-lg",
